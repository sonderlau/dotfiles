{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "wbBg": "#1a1510",
    "wbPanelBg": "#1f1b15",
    "wbEditorBg": "#24201a",
    "wbBorder": "#2e2a24",
    "wbBorderActive": "#3d3830",
    "wbFg": "#bfbdb6",
    "wbUiFg": "#8a8680",
    "wbKeyword": "#ff8f40",
    "wbFunc": "#ffb454",
    "wbOperator": "#f29668",
    "wbDecorator": "#e6c08a",
    "wbType": "#90aec0",
    "wbString": "#b4bc78",
    "wbRegex": "#96b898",
    "wbConstant": "#d4a8b8",
    "wbTag": "#dc9e92",
    "wbMember": "#ec9878",
    "wbComment": "#b4a89c",
    "wbError": "#f49090",
    "wbCssProp": "#deb074"
  },
  "theme": {
    "primary": {
      "dark": "wbFunc",
      "light": "wbFunc"
    },
    "secondary": {
      "dark": "wbType",
      "light": "wbType"
    },
    "accent": {
      "dark": "wbDecorator",
      "light": "wbDecorator"
    },
    "error": {
      "dark": "wbError",
      "light": "wbError"
    },
    "warning": {
      "dark": "wbKeyword",
      "light": "wbKeyword"
    },
    "success": {
      "dark": "wbString",
      "light": "wbString"
    },
    "info": {
      "dark": "wbType",
      "light": "wbType"
    },
    "text": {
      "dark": "wbFg",
      "light": "wbUiFg"
    },
    "textMuted": {
      "dark": "wbUiFg",
      "light": "#6c6862"
    },
    "background": {
      "dark": "wbBg",
      "light": "wbFg"
    },
    "backgroundPanel": {
      "dark": "wbPanelBg",
      "light": "#6c6862"
    },
    "backgroundElement": {
      "dark": "wbEditorBg",
      "light": "wbUiFg"
    },
    "border": {
      "dark": "wbBorder",
      "light": "#6c6862"
    },
    "borderActive": {
