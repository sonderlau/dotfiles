    "markdownCodeBlock": {
      "dark": "wbFg",
      "light": "wbUiFg"
    },
    "syntaxComment": {
      "dark": "wbComment",
      "light": "wbComment"
    },
    "syntaxKeyword": {
      "dark": "wbKeyword",
      "light": "wbKeyword"
    },
    "syntaxFunction": {
      "dark": "wbFunc",
      "light": "wbFunc"
    },
    "syntaxVariable": {
      "dark": "wbTag",
      "light": "wbTag"
    },
    "syntaxString": {
      "dark": "wbString",
      "light": "wbString"
    },
    "syntaxNumber": {
      "dark": "wbConstant",
      "light": "wbConstant"
    },
    "syntaxType": {
      "dark": "wbType",
      "light": "wbType"
    },
    "syntaxOperator": {
      "dark": "wbOperator",
      "light": "wbOperator"
    },
    "syntaxPunctuation": {
      "dark": "wbFg",
      "light": "wbUiFg"
    },
    "inputBackground": {
      "dark": "wbEditorBg",
      "light": "wbFg"
    },
    "InputBorder": {
      "dark": "wbBorder",
      "light": "#6c6862"
    },
    "InputBorderActive": {
      "dark": "wbFunc",
      "light": "wbFunc"
    },
    "inputPrompt": {
      "dark": "wbFunc",
      "light": "wbFunc"
    },
    "inputCursor": {
      "dark": "wbFunc",
      "light": "wbFunc"
    },
    "inputText": {
      "dark": "wbFg",
      "light": "wbUiFg"
    }
